{
  "name": "Next.js SaaS",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "mounts": [
    "source=${localEnv:HOME}/.npm-cache,target=/home/node/.npm,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.next-cache,target=/workspaces/others/.next,type=bind,consistency=cached"
  ],
  "postCreateCommand": "npm ci",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}